msgstr "Één sleutel per regel. Wildcards ondersteund: _mijn_prefix_*"

#: src/Views/admin/settings-page.php
msgid "Ignored option names"
msgstr "Genegeerde optienamen"

#: src/Views/admin/settings-page.php
msgid "One option name per line. Wildcards supported: my_plugin_*"
msgstr "Één optienaam per regel. Wildcards ondersteund: mijn_plugin_*"

