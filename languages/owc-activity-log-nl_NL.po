#: src/Views/admin/settings-page.php:68
msgid "When enabled, the IP address of the user is stored with each log entry."
msgstr "Indien ingeschakeld wordt het IP-adres van de gebruiker bij elke logregel opgeslagen."

#: src/Views/admin/settings-page.php:37
msgid "Log retention (days)"
msgstr "Logbehoud (dagen)"

#: src/Views/admin/settings-page.php:49
msgid "Log entries older than this number of days are deleted automatically."
msgstr "Logregels ouder dan dit aantal dagen worden automatisch verwijderd."

