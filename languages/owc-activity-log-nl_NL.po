#. Plugin Name of the plugin
#: owc-activity-log.php
msgid "OWC Activity Log"
msgstr "OWC Activiteitenlog"

#. Description of the plugin
#: owc-activity-log.php
msgid "Tracks all WordPress activity such as posts, meta, options, users, taxonomy, comments, plugins, themes and more."
msgstr "Registreert alle WordPress-activiteit zoals berichten, meta, opties, gebruikers, taxonomieën, reacties, plugins, thema's en meer."

